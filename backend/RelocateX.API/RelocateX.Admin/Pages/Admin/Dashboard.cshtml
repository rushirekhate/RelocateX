@page
@model RelocateX.Admin.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- ═══════════════════════════════════════
     STAT CARDS ROW
═══════════════════════════════════════ -->
<div class="row g-4 mb-4">

    <!-- Total Bookings -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-gradient-blue">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Bookings</div>
                    <div class="stat-value">@Model.TotalBookings</div>
                    <small style="opacity:0.8; font-size:0.78rem;">All time</small>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-calendar2-check-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Bookings -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-gradient-orange">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Pending</div>
                    <div class="stat-value">@Model.PendingBookings</div>
                    <small style="opacity:0.8; font-size:0.78rem;">Awaiting confirmation</small>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Users -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-gradient-green">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value">@Model.TotalUsers</div>
                    <small style="opacity:0.8; font-size:0.78rem;">Registered users</small>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Completed Bookings -->
    <div class="col-xl-3 col-md-6">
        <div class="stat-card bg-gradient-red">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Completed</div>
                    <div class="stat-value">@Model.CompletedBookings</div>
                    <small style="opacity:0.8; font-size:0.78rem;">Successfully done</small>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ═══════════════════════════════════════
     RECENT BOOKINGS + QUICK STATS
═══════════════════════════════════════ -->
<div class="row g-4">

    <!-- Recent Bookings Table -->
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-calendar2-check me-2 text-primary"></i>Recent Bookings</span>
                <a href="/Admin/Bookings" class="btn btn-sm btn-outline-secondary" style="font-size:0.78rem;">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentBookings.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Customer</th>
                                    <th>City</th>
                                    <th>Shift Date</th>
                                    <th>House Size</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.RecentBookings)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div style="font-weight:500;">@b.FullName</div>
                                            <div style="font-size:0.78rem; color:#6b7280;">@b.Phone</div>
                                        </td>
                                        <td>@b.City</td>
                                        <td>@b.ShiftDate?.ToString("dd MMM yyyy")</td>
                                        <td>@b.HouseSize</td>
                                        <td>
                                            <span class="badge @GetStatusBadge(b.Status) px-2 py-1" style="border-radius:6px; font-size:0.75rem;">
                                                @b.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size:2.5rem; opacity:0.3;"></i>
                        <p class="mt-2 mb-0" style="font-size:0.88rem;">No bookings yet</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="col-xl-4">

        <!-- Booking Status Summary -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="bi bi-pie-chart me-2 text-primary"></i>Booking Status
            </div>
            <div class="card-body">
                <!-- Pending -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.82rem; font-weight:500;">Pending</span>
                        <span style="font-size:0.82rem; color:#6b7280;">@Model.PendingBookings</span>
                    </div>
                    <div class="progress" style="height:6px; border-radius:4px;">
                        <div class="progress-bar bg-warning" style="width:@Model.GetPercent(Model.PendingBookings)%"></div>
                    </div>
                </div>
                <!-- Confirmed -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.82rem; font-weight:500;">Confirmed</span>
                        <span style="font-size:0.82rem; color:#6b7280;">@Model.ConfirmedBookings</span>
                    </div>
                    <div class="progress" style="height:6px; border-radius:4px;">
                        <div class="progress-bar bg-success" style="width:@Model.GetPercent(Model.ConfirmedBookings)%"></div>
                    </div>
                </div>
                <!-- Completed -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.82rem; font-weight:500;">Completed</span>
                        <span style="font-size:0.82rem; color:#6b7280;">@Model.CompletedBookings</span>
                    </div>
                    <div class="progress" style="height:6px; border-radius:4px;">
                        <div class="progress-bar" style="width:@Model.GetPercent(Model.CompletedBookings)%; background:#2563eb;"></div>
                    </div>
                </div>
                <!-- Cancelled -->
                <div class="mb-1">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:0.82rem; font-weight:500;">Cancelled</span>
                        <span style="font-size:0.82rem; color:#6b7280;">@Model.CancelledBookings</span>
                    </div>
                    <div class="progress" style="height:6px; border-radius:4px;">
                        <div class="progress-bar bg-danger" style="width:@Model.GetPercent(Model.CancelledBookings)%"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Links -->
        <div class="card">
            <div class="card-header">
                <i class="bi bi-lightning-charge me-2 text-primary"></i>Quick Actions
            </div>
            <div class="card-body d-grid gap-2">
                <a href="/Admin/Bookings" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-calendar2-check me-2"></i>Manage Bookings
                </a>
                <a href="/Admin/Vehicles" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-truck me-2"></i>Manage Vehicles
                </a>
                <a href="/Admin/Pricing" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-currency-rupee me-2"></i>Update Pricing
                </a>
                <a href="/Admin/Users" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-people me-2"></i>View Users
                </a>
                <a href="/Admin/Categories" class="btn btn-outline-primary btn-sm text-start">
                    <i class="bi bi-tags me-2"></i>Manage Categories
                </a>
            </div>
        </div>

    </div>
</div>

@functions {
    string GetStatusBadge(string? status) => status switch
    {
        "Confirmed" => "badge-confirmed",
        "Cancelled" => "badge-cancelled",
        "Completed" => "badge-completed",
        _ => "badge-pending"
    };
}
