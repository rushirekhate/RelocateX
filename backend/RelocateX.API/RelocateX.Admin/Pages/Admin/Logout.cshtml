<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RelocateX Admin</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
            * {
                font-family: 'Inter', sans-serif;
            }

            body {
                background-color: #f0f2f5;
                min-height: 100vh;
            }

            /* ── Sidebar ── */
            #sidebar {
                width: 260px;
                min-height: 100vh;
                background: linear-gradient(180deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1000;
                transition: width 0.3s ease;
                overflow-x: hidden;
            }

            .sidebar-brand {
                padding: 20px 24px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
            }

            .sidebar-brand h4 {
                color: #fff;
                font-weight: 700;
                font-size: 1.2rem;
                margin: 0;
                letter-spacing: 0.5px;
            }

            .sidebar-brand span {
                color: #e94560;
            }

            .sidebar-brand small {
                color: rgba(255,255,255,0.45);
                font-size: 0.72rem;
            }

            .nav-section-label {
                color: rgba(255,255,255,0.35);
                font-size: 0.68rem;
                font-weight: 600;
                letter-spacing: 1.2px;
                text-transform: uppercase;
                padding: 20px 24px 6px;
            }

            .sidebar-nav .nav-link {
                color: rgba(255,255,255,0.65);
                padding: 10px 24px;
                border-radius: 0;
                display: flex;
                align-items: center;
                gap: 12px;
                font-size: 0.875rem;
                font-weight: 500;
                transition: all 0.2s ease;
                border-left: 3px solid transparent;
                text-decoration: none;
            }

            .sidebar-nav .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,0.07);
                border-left-color: rgba(233,69,96,0.5);
            }

            .sidebar-nav .nav-link.active {
                color: #fff;
                background: rgba(233,69,96,0.15);
                border-left-color: #e94560;
            }

            .sidebar-nav .nav-link i {
                font-size: 1.05rem;
                width: 20px;
                text-align: center;
            }

            /* ── Main Content ── */
            #main-content {
                margin-left: 260px;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* ── Top Navbar ── */
            .top-navbar {
                background: #fff;
                border-bottom: 1px solid #e8ecef;
                padding: 0 28px;
                height: 64px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                position: sticky;
                top: 0;
                z-index: 999;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            }

            .top-navbar .page-title {
                font-size: 1.1rem;
                font-weight: 600;
                color: #1a1a2e;
                margin: 0;
            }

            .admin-avatar {
                width: 36px;
                height: 36px;
                background: linear-gradient(135deg, #e94560, #0f3460);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-weight: 700;
                font-size: 0.85rem;
            }

            /* ── Page Content ── */
            .page-content {
                padding: 28px;
                flex: 1;
            }

            /* ── Cards ── */
            .card {
                border: none;
                border-radius: 12px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            }

            .card-header {
                background: #fff;
                border-bottom: 1px solid #f0f2f5;
                border-radius: 12px 12px 0 0 !important;
                padding: 16px 20px;
                font-weight: 600;
                font-size: 0.95rem;
                color: #1a1a2e;
            }

            /* ── Stat Cards ── */
            .stat-card {
                border-radius: 12px;
                padding: 22px;
                color: #fff;
                position: relative;
                overflow: hidden;
            }

            .stat-card .stat-icon {
                width: 50px;
                height: 50px;
                background: rgba(255,255,255,0.2);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.4rem;
            }

            .stat-card .stat-value {
                font-size: 1.9rem;
                font-weight: 700;
                line-height: 1;
                margin: 10px 0 4px;
            }

            .stat-card .stat-label {
                font-size: 0.82rem;
                opacity: 0.85;
            }

            .bg-gradient-blue   { background: linear-gradient(135deg, #2563eb, #1d4ed8); }
            .bg-gradient-green  { background: linear-gradient(135deg, #059669, #047857); }
            .bg-gradient-orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
            .bg-gradient-red    { background: linear-gradient(135deg, #e94560, #c41040); }

            /* ── Badges ── */
            .badge-pending    { background: #fff3cd; color: #856404; }
            .badge-confirmed  { background: #d1fae5; color: #065f46; }
            .badge-cancelled  { background: #fee2e2; color: #991b1b; }
            .badge-completed  { background: #dbeafe; color: #1e40af; }

            /* ── Table ── */
            .table th {
                font-size: 0.78rem;
                font-weight: 600;
                color: #6b7280;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border-top: none;
                background: #f9fafb;
            }

            .table td {
                font-size: 0.875rem;
                color: #374151;
                vertical-align: middle;
            }

            /* ── Buttons ── */
            .btn-primary {
                background: #e94560;
                border-color: #e94560;
            }

            .btn-primary:hover {
                background: #c41040;
                border-color: #c41040;
            }

            /* ── Form Controls ── */
            .form-control:focus, .form-select:focus {
                border-color: #e94560;
                box-shadow: 0 0 0 0.2rem rgba(233,69,96,0.15);
            }

            /* ── Scrollbar ── */
            ::-webkit-scrollbar { width: 5px; }
            ::-webkit-scrollbar-track { background: #f1f1f1; }
            ::-webkit-scrollbar-thumb { background: #c0c0c0; border-radius: 4px; }
    </style>
</head>
<body>

    <!-- ═══════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════ -->
    <div id="sidebar">
        <!-- Brand -->
        <div class="sidebar-brand">
            <h4><span>Relocate</span>X</h4>
            <small>Admin Panel</small>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav mt-1">

            <div class="nav-section-label">Main</div>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Dashboard" ? "active" : "")"
                   href="/Admin/Dashboard">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>

            <div class="nav-section-label">Bookings</div>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Bookings") == true ? "active" : "")"
                   href="/Admin/Bookings">
                <i class="bi bi-calendar2-check-fill"></i> All Bookings
            </a>

            <div class="nav-section-label">Master Data</div>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Vehicles") == true ? "active" : "")"
                   href="/Admin/Vehicles">
                <i class="bi bi-truck-fill"></i> Vehicles
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Pricing") == true ? "active" : "")"
                   href="/Admin/Pricing">
                <i class="bi bi-currency-rupee"></i> Km-wise Pricing
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Categories") == true ? "active" : "")"
                   href="/Admin/Categories">
                <i class="bi bi-tags-fill"></i> Categories
            </a>

            <div class="nav-section-label">Users</div>

            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Admin/Users") == true ? "active" : "")"
                   href="/Admin/Users">
                <i class="bi bi-people-fill"></i> All Users
            </a>

            <div class="nav-section-label">Account</div>

            <a class="nav-link" href="/Admin/Logout">
                <i class="bi bi-box-arrow-left"></i> Logout
            </a>

        </nav>
    </div>

    <!-- ═══════════════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════════════ -->
    <div id="main-content">

        <!-- Top Navbar -->
        <div class="top-navbar">
            <h6 class="page-title">@(ViewData["Title"] ?? "Dashboard")</h6>
            <div class="d-flex align-items-center gap-3">
                <span style="font-size:0.82rem; color:#6b7280;">
                    <i class="bi bi-circle-fill text-success" style="font-size:0.5rem;"></i>
                    &nbsp;Online
                </span>
                <div class="d-flex align-items-center gap-2">
                    <div class="admin-avatar">@(Context.Session.GetString("AdminName")?.Substring(0,1).ToUpper() ?? "A")</div>
                    <div>
                        <div style="font-size:0.82rem; font-weight:600; color:#1a1a2e; line-height:1.2;">@(Context.Session.GetString("AdminName") ?? "Admin")</div>
                        <div style="font-size:0.72rem; color:#6b7280;">Super Admin</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Page Body -->
        <div class="page-content">
            @RenderBody()
        </div>

    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
