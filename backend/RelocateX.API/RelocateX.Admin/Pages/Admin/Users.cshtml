@page
@model RelocateX.Admin.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1" style="font-weight:700; color:#1a1a2e;">All Users</h5>
        <p class="mb-0" style="font-size:0.82rem; color:#6b7280;">
            Total <strong>@Model.TotalCount</strong> registered users
        </p>
    </div>
</div>

<!-- SUCCESS / ERROR -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" style="border-radius:10px; border:none;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" style="border-radius:10px; border:none;">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
    </div>
}

<!-- SEARCH BAR -->
<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label" style="font-size:0.78rem; font-weight:600; color:#6b7280;">SEARCH</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:#f9fafb; border-right:none;">
                            <i class="bi bi-search" style="font-size:0.8rem; color:#9ca3af;"></i>
                        </span>
                        <input type="text" name="search" value="@Model.SearchTerm"
                               class="form-control" placeholder="Name, email, phone..."
                               style="border-left:none; background:#f9fafb;" />
                    </div>
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <a href="/Admin/Users" class="btn btn-outline-secondary ms-2">
                            <i class="bi bi-x-lg me-1"></i> Clear
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<!-- USERS TABLE -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Users.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">#</th>
                            <th>User</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Verified</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            <tr>
                                <td class="ps-4" style="color:#9ca3af;">#@u.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:34px; height:34px; border-radius:50%;
                                            background:linear-gradient(135deg,#e94560,#0f3460);
                                            display:flex; align-items:center; justify-content:center;
                                            color:#fff; font-weight:700; font-size:0.78rem; flex-shrink:0;">
                                            @(u.FullName?.Substring(0, 1).ToUpper() ?? "?")
                                        </div>
                                        <div>
                                            <div style="font-weight:500; font-size:0.875rem;">@u.FullName</div>
                                            <div style="font-size:0.75rem; color:#6b7280;">@u.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-size:0.875rem;">@u.Phone</td>
                                <td>
                                    <span class="badge" style="background:#eff6ff; color:#1d4ed8; border-radius:6px; font-size:0.75rem;">
                                        @u.Role
                                    </span>
                                </td>
                                <td>
                                    @if (u.IsVerified)
                                    {
                                        <span class="badge badge-confirmed px-2 py-1" style="border-radius:6px; font-size:0.75rem;">
                                            <i class="bi bi-check-circle-fill me-1"></i>Verified
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-pending px-2 py-1" style="border-radius:6px; font-size:0.75rem;">
                                            <i class="bi bi-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                                <td style="font-size:0.82rem; color:#6b7280;">
                                    @u.CreatedAt?.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @if (u.IsBlocked)
                                    {
                                        <span class="badge badge-cancelled px-2 py-1" style="border-radius:6px; font-size:0.75rem;">
                                            <i class="bi bi-slash-circle me-1"></i>Blocked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-confirmed px-2 py-1" style="border-radius:6px; font-size:0.75rem;">
                                            <i class="bi bi-check2 me-1"></i>Active
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (u.IsBlocked)
                                    {
                                        <form method="post" asp-page-handler="ToggleBlock" style="display:inline;">
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <input type="hidden" name="isBlocked" value="false" />
                                            <button type="submit" class="btn btn-sm btn-outline-success"
                                                    style="font-size:0.75rem;"
                                                    onclick="return confirm('Unblock this user?')">
                                                <i class="bi bi-unlock me-1"></i>Unblock
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="ToggleBlock" style="display:inline;">
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <input type="hidden" name="isBlocked" value="true" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    style="font-size:0.75rem;"
                                                    onclick="return confirm('Block this user?')">
                                                <i class="bi bi-slash-circle me-1"></i>Block
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people" style="font-size:2.5rem; opacity:0.3;"></i>
                <p class="mt-2 mb-0" style="font-size:0.88rem;">No users found</p>
            </div>
        }
    </div>
</div>
