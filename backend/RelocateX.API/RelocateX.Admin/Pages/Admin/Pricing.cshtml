@page
@model RelocateX.Admin.Pages.Admin.PricingModel
@{
    ViewData["Title"] = "Km-wise Pricing";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1" style="font-weight:700; color:#1a1a2e;">Km-wise Pricing</h5>
        <p class="mb-0" style="font-size:0.82rem; color:#6b7280;">
            Set pricing slabs per vehicle — <strong>@Model.PricingRules.Count</strong> rules configured
        </p>
    </div>
    @if (Model.Vehicles.Any())
    {
        <button class="btn btn-primary" onclick="openAddModal()">
            <i class="bi bi-plus-lg me-2"></i>Add Pricing Rule
        </button>
    }
    else
    {
        <a href="/Admin/Vehicles" class="btn btn-outline-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>Add Vehicles First
        </a>
    }
</div>

<!-- SUCCESS / ERROR -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4" style="border-radius:10px; border:none;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" style="border-radius:10px; border:none;">
        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
    </div>
}

<!-- INFO CARD -->
<div class="alert mb-4" style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; color:#1e40af;">
    <i class="bi bi-info-circle-fill me-2"></i>
    <strong>How pricing works:</strong> Set km slabs per vehicle.
    e.g. Truck: 0–10km = ₹50/km + ₹500 base, 11–30km = ₹40/km + ₹500 base.
    Leave <strong>Max Km</strong> empty for "above X km" slab.
</div>

<!-- PRICING TABLE -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.PricingRules.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Vehicle</th>
                            <th>Km Range</th>
                            <th>Base Charge</th>
                            <th>Price / Km</th>
                            <th>Est. 20km Total</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.PricingRules)
                        {
                            var kmRange = p.MaxKm.HasValue
                                ? $"{p.MinKm} – {p.MaxKm} km"
                                : $"Above {p.MinKm} km";

                            // Estimate for 20 km if in range
                            var est = p.BaseCharge + (20 * p.PricePerKm);

                            <tr>
                                <td class="ps-4" style="color:#9ca3af;">#@p.Id</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px; height:32px; border-radius:8px;
                                            background:linear-gradient(135deg,#059669,#047857);
                                            display:flex; align-items:center; justify-content:center;
                                            color:#fff; font-size:0.8rem; flex-shrink:0;">
                                            <i class="bi bi-truck-fill"></i>
                                        </div>
                                        <span style="font-weight:500;">@p.VehicleName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge" style="background:#f3f4f6; color:#374151; font-size:0.8rem; border-radius:6px;">
                                        <i class="bi bi-signpost-2 me-1"></i>@kmRange
                                    </span>
                                </td>
                                <td style="font-weight:600; color:#1a1a2e;">
                                    ₹@p.BaseCharge.ToString("N0")
                                </td>
                                <td style="font-weight:600; color:#2563eb;">
                                    ₹@p.PricePerKm / km
                                </td>
                                <td style="font-size:0.82rem; color:#6b7280;">
                                    ₹@est.ToString("N0")
                                </td>
                                <td>
                                    @if (p.IsActive)
                                    {
                                        <span class="badge badge-confirmed px-2 py-1" style="border-radius:6px; font-size:0.75rem;">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-cancelled px-2 py-1" style="border-radius:6px; font-size:0.75rem;">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-secondary me-1"
                                            style="font-size:0.75rem;"
                                            onclick="openEditModal(@p.Id, @p.VehicleId, @p.MinKm, '@(p.MaxKm?.ToString() ?? "")', @p.PricePerKm, @p.BaseCharge, @p.IsActive.ToString().ToLower())">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" style="display:inline;">
                                        <input type="hidden" name="pricingId" value="@p.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                style="font-size:0.75rem;"
                                                onclick="return confirm('Delete this pricing rule?')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-currency-rupee" style="font-size:2.5rem; opacity:0.3;"></i>
                <p class="mt-2 mb-0" style="font-size:0.88rem;">No pricing rules yet. Add your first slab!</p>
            </div>
        }
    </div>
</div>

<!-- ═══ ADD MODAL ═══ -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px; border:none;">
            <div class="modal-header" style="border-bottom:1px solid #f0f2f5;">
                <h6 class="modal-title" style="font-weight:700;">Add Pricing Rule</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Add">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.82rem; font-weight:600;">Vehicle <span class="text-danger">*</span></label>
                        <select name="Pricing.VehicleId" class="form-select" required>
                            <option value="">-- Select Vehicle --</option>
                            @foreach (var v in Model.Vehicles)
                            {
                                <option value="@v.Id">@v.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Min Km <span class="text-danger">*</span></label>
                            <input type="number" name="Pricing.MinKm" class="form-control" placeholder="0" min="0" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">
                                Max Km
                                <span style="font-size:0.72rem; color:#6b7280;">(empty = unlimited)</span>
                            </label>
                            <input type="number" name="Pricing.MaxKm" class="form-control" placeholder="e.g. 30" min="1" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Base Charge (₹) <span class="text-danger">*</span></label>
                            <input type="number" name="Pricing.BaseCharge" class="form-control" placeholder="500" min="0" step="0.01" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Price per Km (₹) <span class="text-danger">*</span></label>
                            <input type="number" name="Pricing.PricePerKm" class="form-control" placeholder="40" min="0" step="0.01" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid #f0f2f5;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Add Rule
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ═══ EDIT MODAL ═══ -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px; border:none;">
            <div class="modal-header" style="border-bottom:1px solid #f0f2f5;">
                <h6 class="modal-title" style="font-weight:700;">Edit Pricing Rule</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Edit">
                <div class="modal-body">
                    <input type="hidden" name="Pricing.Id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.82rem; font-weight:600;">Vehicle <span class="text-danger">*</span></label>
                        <select name="Pricing.VehicleId" id="editVehicleId" class="form-select" required>
                            @foreach (var v in Model.Vehicles)
                            {
                                <option value="@v.Id">@v.Name</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Min Km</label>
                            <input type="number" name="Pricing.MinKm" id="editMinKm" class="form-control" min="0" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Max Km</label>
                            <input type="number" name="Pricing.MaxKm" id="editMaxKm" class="form-control" min="1" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Base Charge (₹)</label>
                            <input type="number" name="Pricing.BaseCharge" id="editBase" class="form-control" step="0.01" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label" style="font-size:0.82rem; font-weight:600;">Price per Km (₹)</label>
                            <input type="number" name="Pricing.PricePerKm" id="editPrice" class="form-control" step="0.01" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.82rem; font-weight:600;">Status</label>
                        <select name="Pricing.IsActive" id="editActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid #f0f2f5;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() {
            new bootstrap.Modal(document.getElementById('addModal')).show();
        }
        function openEditModal(id, vehicleId, minKm, maxKm, price, base, isActive) {
            document.getElementById('editId').value        = id;
            document.getElementById('editVehicleId').value = vehicleId;
            document.getElementById('editMinKm').value     = minKm;
            document.getElementById('editMaxKm').value     = maxKm;
            document.getElementById('editPrice').value     = price;
            document.getElementById('editBase').value      = base;
            document.getElementById('editActive').value    = isActive.toString();
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
